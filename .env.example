# Twenty Cloud: omit TWENTY_BASE_URL (defaults to https://api.twenty.com)
# Self-hosted Twenty: set your private or public instance URL
# TWENTY_BASE_URL=https://crm.example.com

# Choose one authentication method.
TWENTY_API_KEY=
# TWENTY_ACCESS_TOKEN=
# TWENTY_CLIENT_ID=
# TWENTY_CLIENT_SECRET=
# TWENTY_OAUTH_SCOPE=api

# Optional request timeout in seconds.
# TWENTY_TIMEOUT_SECONDS=30
