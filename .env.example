# Default: Hermes manages a self-hosted Twenty stack in ~/.hermes/projects/twenty-crm.
TWENTY_CONNECTION_MODE=managed
TWENTY_MANAGED_AUTOSTART=true
TWENTY_MANAGED_BIND_HOST=127.0.0.1
TWENTY_MANAGED_PORT=3000
# TWENTY_MANAGED_PROJECT_DIR=~/.hermes/projects/twenty-crm
# TWENTY_MANAGED_IMAGE_TAG=latest

# After first start, create a Twenty API key in the Twenty UI and set it here.
TWENTY_API_KEY=
# TWENTY_ACCESS_TOKEN=
# TWENTY_CLIENT_ID=
# TWENTY_CLIENT_SECRET=
# TWENTY_OAUTH_SCOPE=api
TWENTY_TIMEOUT_SECONDS=30

# To connect instead of run a local stack, switch modes and set an address.
# This can be localhost, a private-LAN address, a VPN/Tailscale hostname, or Twenty Cloud.
# TWENTY_CONNECTION_MODE=external
# TWENTY_BASE_URL=https://crm.example.com
